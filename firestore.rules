rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }
      
      function isOwner(uid) {
        return isSignedIn() && request.auth.uid == uid;
      }

      function isValidId(id) {
        return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
      }

      function incoming() {
        return request.resource.data;
      }

      function existing() {
        return resource.data;
      }

      // Tasks Collection
      match /tasks/{taskId} {
        function isValidTask(data) {
          return data.id is string && data.id.size() <= 128 &&
                 data.title is string && data.title.size() <= 200 &&
                 data.completed is bool &&
                 data.priority in ['low', 'medium', 'high'] &&
                 data.category is string && data.category.size() <= 50;
        }

        allow read, list: if isOwner(userId);
        
        allow create: if isOwner(userId) && 
                      isValidId(taskId) && 
                      isValidTask(incoming()) &&
                      incoming().createdAt == request.time;
        
        allow update: if isOwner(userId) && 
                      isValidTask(incoming()) &&
                      incoming().id == existing().id &&
                      incoming().createdAt == existing().createdAt;
        
        allow delete: if isOwner(userId);
      }

      // Stats Document
      match /stats/main {
        function isValidStats(data) {
          return data.completedToday is int &&
                 data.totalCompleted is int &&
                 data.streak is int &&
                 data.focusMinutes is int &&
                 data.aiSuggestionsUsed is int;
        }

        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidStats(incoming());
      }
    }
  }
}
